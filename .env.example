# Supabase (required for auth, including Google OAuth)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (required for payment redirect after checkout)
# Set this to your actual deployed URL in production (no trailing slash)
# e.g. https://mufassir-iota.vercel.app
NEXT_PUBLIC_APP_URL=https://mufassir-iota.vercel.app

# Mayar Payment Gateway
# Get API key from: https://mayar.id → Developer → API Keys
# MAYAR_SANDBOX=true  → uses api.mayar.club (sandbox/testing)
# MAYAR_SANDBOX=false → uses api.mayar.id  (production)
# Make sure the API key matches the environment (sandbox key for sandbox, production key for production)
MAYAR_API_KEY=your-mayar-api-key
MAYAR_SANDBOX=true

# Cerebras AI (required for AI chat feature)
# Get API key from: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-api-key
